{
  "name": "parkins-off-landing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist",
    "deploy:docs": "vite build && powershell -Command \"if (Test-Path docs) { Remove-Item -Recurse -Force docs }; New-Item -ItemType Directory -Force docs | Out-Null; Copy-Item -Recurse dist\\* docs\""
  },
  "dependencies": {
    "framer-motion": "^11.3.24",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.1.1",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.8"
  }
}
